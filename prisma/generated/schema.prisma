// schema.prisma

generator client {
  provider   = "prisma-client-js"
  output     = "./generated"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  supervisor
  student
}

model User {
  id             String   @id @default(cuid())
  firstName      String
  middleName     String
  lastName       String
  email          String   @unique
  hashedPassword String
  birthYear      Int
  role           Role     @default(student)
  createdAt      DateTime @default(now()) @map(name: "created_at")
  updatedAt      DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "users")
}
