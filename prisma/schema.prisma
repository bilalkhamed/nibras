// schema.prisma

generator client {
  provider   = "prisma-client-js"
  output     = "./generated"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  supervisor
  student
}

enum UserStatus {
  active
  suspended
  invited
  deleted
}

enum CohortStatus {
  active
  archived
}

enum CohortLevels {
  level1
  level2
  level3
  level4
}

model User {
  id             String     @id @default(cuid(2))
  firstName      String
  middleName     String
  lastName       String
  email          String?    @unique
  hashedPassword String?
  birthYear      Int
  role           Role       @default(student)
  status         UserStatus @default(active)
  country        String?
  phone          String?

  groupsAsSupervisor Group[]        @relation("SupervisedGroups")
  groupsAsStudent    GroupStudent[] @relation("StudentGroups")

  cohort   Cohort? @relation("CohortStudents", fields: [cohortId], references: [id])
  cohortId String?

  invite Invite?

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@index([role])
  @@index([role, status])
  @@index([cohortId, role])
  @@map("users")
}

model Group {
  id   String @id @default(cuid(2))
  name String
  code String @unique

  cohortId     String
  cohort       Cohort @relation(fields: [cohortId], references: [id])
  supervisorId String
  supervisor   User   @relation("SupervisedGroups", fields: [supervisorId], references: [id])

  students GroupStudent[]

  // status GroupStatus @default(active)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([cohortId, name])
  @@index([cohortId])
  @@index([supervisorId])
  @@index([cohortId, supervisorId])
  @@map("groups")
}

model Cohort {
  id           String       @id @default(cuid(2))
  name         String
  slug         String       @unique
  startDate    DateTime
  endDate      DateTime?
  entryLevel   CohortLevels @default(level1)
  groups       Group[]
  students     User[]       @relation("CohortStudents")
  status       CohortStatus @default(active)
  label        String
  currentLevel CohortLevels @default(level1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("cohorts")
}

model GroupStudent {
  id String @id @default(cuid(2))

  groupId   String
  studentId String

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student User  @relation("StudentGroups", fields: [studentId], references: [id], onDelete: Cascade)

  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  isActive Boolean   @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([groupId, isActive])
  @@index([studentId, isActive])
  @@map("group_students")
}

model Invite {
  id            String @id @default(cuid(2))
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  selector      String @unique
  validatorHash String @map("validator_hash")

  attempts Int @default(0)

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([selector])
  @@map("invites")
}
