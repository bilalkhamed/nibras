// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  cohort_manager
  group_manager
  supervisor
  student
  media_team
}

enum UserStatus {
  active
  suspended
  invited
  deleted
}

enum CohortStatus {
  active
  archived
}

enum SupervisorStatus {
  in_training
  trained
}

model User {
  id             String     @id @default(cuid(2))
  firstName      String
  middleName     String
  lastName       String
  email          String?    @unique
  username       String?    @unique @db.VarChar(50)
  hashedPassword String?
  birthYear      Int
  role           Role       @default(student)
  status         UserStatus @default(active)
  country        String?
  phone          String?

  groupsAsStudent GroupStudent[] @relation("StudentGroups")

  supervisedGroupId String?
  supervisedGroup   Group?            @relation("GroupSupervisors", fields: [supervisedGroupId], references: [id])
  supervisorStatus  SupervisorStatus?

  managedGroups  GroupManager[]  @relation("UserGroupManagers")
  managedCohorts CohortManager[] @relation("UserCohortManagers")

  cohort   Cohort? @relation("CohortStudents", fields: [cohortId], references: [id])
  cohortId String?

  invite Invite?

  studentAssignments StudentAssignment[]
  markedAssignments  StudentAssignment[] @relation("markedBy")
  gradedAssignments  StudentAssignment[] @relation("gradedBy")

  articles Article[]

  studentProfile StudentProfile?

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@index([role])
  @@index([role, status])
  @@index([cohortId, role])
  @@index([supervisedGroupId])
  @@map("users")
}

enum GradeLevel {
  first_grade
  second_grade
  third_grade
  fourth_grade
  fifth_grade
  sixth_grade
  seventh_grade
  eighth_grade
  ninth_grade
  tenth_grade
  eleventh_grade
  twelfth_grade
  bachelor
}

model StudentProfile {
  id String @id @default(cuid(2))

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Additional fields for student profile
  address        String?
  motherFullName String?
  motherPhone    String?
  gradeLevel     GradeLevel?
  skills         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("student_profiles")
}

model Group {
  id   String @id @default(cuid(2))
  name String
  code String @unique

  cohortId    String
  cohort      Cohort         @relation(fields: [cohortId], references: [id])
  supervisors User[]         @relation("GroupSupervisors")
  managers    GroupManager[] @relation("GroupGroupManagers")

  students GroupStudent[]

  // status GroupStatus @default(active)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([cohortId, name])
  @@index([cohortId])
  @@map("groups")
}

model GroupManager {
  id String @id @default(cuid(2))

  groupId String @unique
  userId  String

  group Group @relation("GroupGroupManagers", fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation("UserGroupManagers", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_managers")
}

model GroupStudent {
  id String @id @default(cuid(2))

  groupId   String
  studentId String

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student User  @relation("StudentGroups", fields: [studentId], references: [id], onDelete: Cascade)

  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  isActive Boolean   @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([groupId, isActive])
  @@index([studentId, isActive])
  @@map("group_students")
}

model Cohort {
  id             String          @id @default(cuid(2))
  name           String
  slug           String          @unique
  startDate      DateTime
  endDate        DateTime?
  entryLevelId   String
  entryLevel     Level           @relation("CohortEntryLevel", fields: [entryLevelId], references: [id])
  groups         Group[]
  students       User[]          @relation("CohortStudents")
  status         CohortStatus    @default(active)
  label          String
  currentLevelId String
  currentLevel   Level           @relation("CohortCurrentLevel", fields: [currentLevelId], references: [id])
  managers       CohortManager[] @relation("CohortCohortManagers")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("cohorts")
}

model CohortManager {
  id String @id @default(cuid(2))

  cohortId String
  userId   String

  cohort Cohort @relation("CohortCohortManagers", fields: [cohortId], references: [id], onDelete: Cascade)
  user   User   @relation("UserCohortManagers", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([cohortId, userId])
  @@index([cohortId])
  @@index([userId])
  @@map("cohort_managers")
}

model Invite {
  id            String @id @default(cuid(2))
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  selector      String @unique
  validatorHash String @map("validator_hash")

  attempts Int @default(0)

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([selector])
  @@map("invites")
}

// New

model Level {
  id          String  @id @default(cuid(2))
  number      Int     @unique
  title       String
  description String?
  slug        String  @unique

  cohortsAsEntryLevel   Cohort[] @relation("CohortEntryLevel")
  cohortsAsCurrentLevel Cohort[] @relation("CohortCurrentLevel")

  assignments Assignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("levels")
}

model Program {
  id          String  @id @default(cuid(2))
  name        String
  description String?
  slug        String  @unique

  isSupervisorOnly Boolean @default(false) @map("is_supervisor_only")

  assignments Assignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("programs")
}

model Week {
  id     String @id @default(cuid(2))
  number Int    @unique
  title  String

  assignments Assignment[]

  calendarWeeks CalendarWeek[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("weeks")
}

model CalendarWeek {
  id        String   @id @default(cuid(2))
  startDate DateTime
  endDate   DateTime

  weekId String
  week   Week   @relation(fields: [weekId], references: [id])

  academicYear Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([weekId, academicYear])
  @@index([academicYear, startDate, endDate])
  @@map("calendar_weeks")
}

enum AssignmentTypes {
  lecture
  exercise
  quiz
  reading
}

model Assignment {
  id          String  @id @default(cuid(2))
  name        String
  description String?
  programId   String
  program     Program @relation(fields: [programId], references: [id])
  weekId      String
  week        Week    @relation(fields: [weekId], references: [id])
  levelId     String
  level       Level   @relation(fields: [levelId], references: [id])

  type        AssignmentTypes        @default(reading)
  attachments AssignmentAttachment[]

  studentAssignments StudentAssignment[]

  allowTextSubmission Boolean @default(false) @map("allow_text_submission")
  allowFileSubmission Boolean @default(false) @map("allow_file_submission")

  maxScore Float @map("max_score")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([programId, weekId, levelId])
  @@map("assignments")
}

enum AttachmentType {
  FILE
  LINK
}

model AssignmentAttachment {
  id           String     @id @default(cuid(2))
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  type AttachmentType @default(FILE)
  name String?

  url     String?
  fileKey String? @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([assignmentId])
  @@map("assignments_attachments")
}

model StudentAssignment {
  id           String @id @default(cuid(2))
  studentId    String
  assignmentId String

  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  isCompleted Boolean   @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  textSubmission String? @map("text_submission")
  fileKey        String? @map("file_key")

  markedById String?
  markedBy   User?   @relation(fields: [markedById], references: [id], onDelete: SetNull, name: "markedBy")

  //grading
  score    Float?
  maxScore Float? @map("max_score")
  comment  String? @db.Text

  gradedById String?
  gradedBy   User?   @relation(fields: [gradedById], references: [id], onDelete: SetNull, name: "gradedBy")

  @@unique([studentId, assignmentId])
  @@index([assignmentId, isCompleted])
  @@index([studentId, isCompleted])
  @@map("student_assignments")
}

// schema.prisma

model Article {
  id            String  @id @default(cuid(2))
  title         String
  slug          String  @unique
  content       String  @db.Text
  coverImageKey String?

  isPublished Boolean @default(true)

  // Who wrote it? (The Media Team)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  category String @default("GENERAL") // News, Religious, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished])
  @@map("articles")
}

